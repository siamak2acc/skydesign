NODE_ENV=production
SITE_URL=https://skydesign.com.au
PORT=3000
TP_MARKER=your_travelpayouts_marker
TP_API_TOKEN=your_travelpayouts_data_api_token
TP_WIDGET_EMBED_URL=
ENABLE_AVIASALES_REDIRECTS=false

# Optional static FTP tooling, if you still use the static deploy workflow.
FTP_HOST=ftp.example.hostinger.com
FTP_PORT=21
FTP_USER=your_ftp_username
FTP_PASSWORD=your_ftp_password
FTP_SECURE=false
FTP_REMOTE_DIR=/public_html
FTP_CLEAR_REMOTE=false
