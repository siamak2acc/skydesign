<%- include('partials/head') %>

<section class="page-hero compact">
  <p class="eyebrow">Flight Deal Finder</p>
  <h1>Search for a flight deal</h1>
  <p>Enter IATA airport codes and dates. SkyDesign checks Travelpayouts server-side, keeps API tokens private, and shows cached fare data when available.</p>
</section>

<section class="tool-shell">
  <%- include('partials/search-form') %>

  <aside class="result-panel">
    <p class="eyebrow">Travelpayouts</p>
    <h2>Secure price lookup</h2>
    <p>Flight prices are requested by the Express backend using the Travelpayouts API token in the `X-Access-Token` header.</p>
    <ul class="check-list">
      <li>Token never reaches frontend code</li>
      <li>Cached data is normal, not guaranteed</li>
      <li>Live booking partner integration is being updated</li>
    </ul>
    <% if (enableAviasalesRedirects && fallbackUrl) { %>
      <a class="button button-secondary fallback-button" href="<%= fallbackUrl %>" rel="nofollow sponsored">Search live flight deals</a>
    <% } else { %>
      <a class="button button-secondary fallback-button" href="<%= liveSearchUrl %>">Search live flight deals</a>
    <% } %>
  </aside>
</section>

<% if (searched) { %>
  <section class="deals-section">
    <div class="section-header">
      <p class="eyebrow">Results</p>
      <h2>Cached flight prices</h2>
      <% if (typeof cached !== 'undefined' && cached) { %>
        <p>Showing cached results from the last 24 hours.</p>
      <% } else { %>
        <p>Cached prices may change when you continue to the booking partner.</p>
      <% } %>
    </div>

    <% if (apiError) { %>
      <div class="empty-state">
        <strong><%= apiError %></strong>
        <span><%= liveSearchMessage %></span>
        <% if (enableAviasalesRedirects && fallbackUrl) { %>
          <a class="button button-primary" href="<%= fallbackUrl %>" rel="nofollow sponsored">Search live flight deals</a>
        <% } else { %>
          <a class="button button-primary" href="<%= liveSearchUrl %>">Search live flight deals</a>
        <% } %>
      </div>
    <% } else if (results && results.length) { %>
      <div class="deal-grid">
        <% results.forEach((deal) => { %>
          <%- include('partials/deal-card', { deal, fetchedAt, enableAviasalesRedirects }) %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <strong><%= noCachedDataMessage || 'No cached price is available for this exact route/date.' %></strong>
        <span>Travelpayouts cached data can be empty for specific routes and dates. <%= liveSearchMessage %></span>
        <% if (enableAviasalesRedirects && fallbackUrl) { %>
          <a class="button button-primary" href="<%= fallbackUrl %>" rel="nofollow sponsored">Search live flight deals</a>
        <% } else { %>
          <a class="button button-primary" href="<%= liveSearchUrl %>">Search live flight deals</a>
        <% } %>
      </div>
    <% } %>
  </section>

  <% if (popularResults && popularResults.length) { %>
    <section class="deals-section popular-deals-section">
      <div class="section-header">
        <p class="eyebrow">Popular cached deals</p>
        <h2>Broader month-level options</h2>
        <p>No exact cached match was found, but these cached fares were found from a broader month-level Travelpayouts search.</p>
      </div>
      <div class="deal-grid">
        <% popularResults.forEach((deal) => { %>
          <%- include('partials/deal-card', { deal, fetchedAt, enableAviasalesRedirects }) %>
        <% }) %>
      </div>
    </section>
  <% } %>
<% } %>

<%- include('partials/footer') %>
