<article class="deal-card">
  <div class="deal-card-header">
    <p class="route-code"><%= deal.origin %> to <%= deal.destination %></p>
    <h3><span><%= deal.currency %></span> <%= Number(deal.price).toLocaleString('en-AU') %></h3>
  </div>
  <dl>
    <div>
      <dt>Departure</dt>
      <dd><%= deal.departDate || 'Flexible' %></dd>
    </div>
    <% if (deal.returnDate) { %>
      <div>
        <dt>Return</dt>
        <dd><%= deal.returnDate %></dd>
      </div>
    <% } %>
    <div>
      <dt>Airline</dt>
      <dd><%= deal.airline || 'Any airline' %></dd>
    </div>
    <div>
      <dt>Stops</dt>
      <dd>
        <% if (deal.transfers === 0) { %>
          Direct
        <% } else if (typeof deal.transfers === 'number') { %>
          <%= deal.transfers %> <%= deal.transfers === 1 ? 'stop' : 'stops' %>
        <% } else { %>
          Not specified
        <% } %>
      </dd>
    </div>
    <% if (deal.foundAt || fetchedAt) { %>
      <div>
        <dt>Last updated</dt>
        <dd><%= deal.foundAt || fetchedAt %></dd>
      </div>
    <% } %>
  </dl>
  <a class="button button-primary" href="<%= deal.dealUrl %>" rel="nofollow sponsored">View Deal</a>
</article>
