<form class="search-form" action="/flight-deal-finder" method="post">
  <% if (typeof error !== 'undefined' && error) { %>
    <p class="form-alert" role="alert"><%= error %></p>
  <% } %>
  <div class="field-grid">
    <label>
      <span>From (IATA)</span>
      <input class="iata-input" name="originIata" type="text" inputmode="latin" maxlength="3" pattern="[A-Za-z]{3}" autocomplete="off" placeholder="SYD" value="<%= typeof formValues !== 'undefined' ? formValues.originIata : '' %>" required>
    </label>
    <label>
      <span>To (IATA)</span>
      <input class="iata-input" name="destinationIata" type="text" inputmode="latin" maxlength="3" pattern="[A-Za-z]{3}" autocomplete="off" placeholder="DXB" value="<%= typeof formValues !== 'undefined' ? formValues.destinationIata : '' %>" required>
    </label>
    <label>
      <span>Departure date</span>
      <input name="departDate" type="date" value="<%= typeof formValues !== 'undefined' ? formValues.departDate : '' %>" required>
    </label>
    <label>
      <span>Return date</span>
      <input name="returnDate" type="date" value="<%= typeof formValues !== 'undefined' ? formValues.returnDate : '' %>">
    </label>
    <label>
      <span>Adults</span>
      <input name="adults" type="number" min="1" max="9" value="<%= typeof formValues !== 'undefined' ? formValues.adults : '1' %>">
    </label>
  </div>
  <button class="button button-primary" type="submit">Search Aviasales</button>
</form>
