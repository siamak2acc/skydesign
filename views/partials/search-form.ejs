<form class="search-form <%= typeof formClass !== 'undefined' ? formClass : '' %>" action="<%= typeof formAction !== 'undefined' ? formAction : '/flight-deal-finder' %>" method="<%= typeof formMethod !== 'undefined' ? formMethod : 'get' %>" <%- typeof formId !== 'undefined' ? `id="${formId}"` : '' %>>
  <% if (typeof error !== 'undefined' && error) { %>
    <p class="form-alert" role="alert"><%= error %></p>
  <% } %>
  <div class="field-grid">
    <label>
      <span>From (IATA)</span>
      <input class="iata-input" name="origin" type="text" inputmode="latin" maxlength="3" pattern="[A-Za-z]{3}" autocomplete="off" placeholder="SYD" value="<%= typeof formValues !== 'undefined' ? formValues.origin : '' %>" required>
    </label>
    <label>
      <span>To (IATA)</span>
      <input class="iata-input" name="destination" type="text" inputmode="latin" maxlength="3" pattern="[A-Za-z]{3}" autocomplete="off" placeholder="DXB" value="<%= typeof formValues !== 'undefined' ? formValues.destination : '' %>" required>
    </label>
    <label>
      <span>Departure date</span>
      <input name="depart_date" type="text" inputmode="numeric" pattern="\d{4}-\d{2}(-\d{2})?" placeholder="2026-06-01 or 2026-06" value="<%= typeof formValues !== 'undefined' ? formValues.depart_date : '' %>" required>
    </label>
    <label>
      <span>Return date</span>
      <input name="return_date" type="text" inputmode="numeric" pattern="\d{4}-\d{2}(-\d{2})?" placeholder="2026-06-10 or 2026-06" value="<%= typeof formValues !== 'undefined' ? formValues.return_date : '' %>">
    </label>
    <label>
      <span>Adults</span>
      <input name="adults" type="number" min="1" max="9" value="<%= typeof formValues !== 'undefined' ? formValues.adults : '1' %>">
    </label>
    <label>
      <span>Currency</span>
      <select name="currency">
        <% ['AUD', 'USD', 'EUR', 'GBP', 'NZD'].forEach((currencyOption) => { %>
          <option value="<%= currencyOption %>" <%= typeof formValues !== 'undefined' && formValues.currency === currencyOption ? 'selected' : '' %>><%= currencyOption %></option>
        <% }) %>
      </select>
    </label>
  </div>
  <button class="button button-primary" type="submit"><%= typeof buttonText !== 'undefined' ? buttonText : 'Search flight prices' %></button>
</form>
